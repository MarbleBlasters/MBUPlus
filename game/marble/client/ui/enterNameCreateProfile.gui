   fontColorNA = "255 255 255";
   cursorColor = "255 255 255";
   textOffset = "0 2";
   shadow = 0;
   doFontOutline = false;
   fontOutlineColor = "0 0 0 30";
   autoSizeWidth = false;
   autoSizeHeight = true;
   tab = true;
   canKeyFocus = true;
};

