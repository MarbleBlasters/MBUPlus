function EnterNameCreateProfileGui::onWake(%this)
{
   %this.gamertag = $Player::Name;

   XNMessagePopupABtnTxt.setText($Text::OK);
   XNMessagePopupBBtnTxt.setText($Text::Cancel);
   XNMessagePopupABtnNew.setText($Text::Ok);
   XNMessagePopupBBtnNew.setText($Text::Cancel);
   XNMessagePopupTextThree.setText("<spush><font:Arial Bold:14>(Make it different from your other passwords!!!)<spop>");

   // XMessagePopupDlg.show(0, "Set Gamertag:", $Text::OK, "EnterNameCreateProfileGui.apply();", $Text::Cancel, "EnterNameCreateProfileGui.cancel();");
   // XMessagePopupDlg.add(ENG_Type);
   %this.schedule(100, fixupText);

	if (%this.mode $= "")
	{
		%this.mode = "CREATE";
	}

	if (%this.mode $= "CREATE")
	{
   		XNMessagePopupTitle.setText("<font:Arial Bold:35>Create Account");
		XNMessagePopupText.setText("Set Username/Display Name:");
		XNMessagePopupTextTwo.setText("Set Recovery Code:");
		XNMessagePopupTextThree.setVisible(true);

		XNMessagePopupTitle.position = "103 75";
		XNMessagePopupText.position = "103 114";
		ENG_Type.position = "100 143";
		XNMessagePopupTextTwo.position = "103 177";
		ENG_TypeRecov.position = "100 222";
	}
	else if (%this.mode $= "LOGIN")
	{
		XNMessagePopupTitle.setText("<font:Arial Bold:35>Log In");
		XNMessagePopupText.setText("Username:");
		XNMessagePopupTextTwo.setText("Recovery Code:");
		XNMessagePopupTextThree.setVisible(false);

		XNMessagePopupTitle.position = "103 81";
		XNMessagePopupText.position = "103 127";
		ENG_Type.position = "100 154";
		XNMessagePopupTextTwo.position = "103 203";
		ENG_TypeRecov.position = "100 229";
	}

   // RootGui.setTitle( "Set Gamertag" );
}

function EnterNameCreateProfileGui::fixupText(%this)
{
   ENG_Type.setValue(%this.gamertag);
   ENG_Type.setCursorPos(strlen(%this.gamertag));
   deactivateKeyboard();
   ENG_Type.makeFirstResponder(true);

   // pls dont ask
   %pos = VectorAdd(
      XMessagePopupText.position,
      VectorAdd(
         XMessagePopupText.getGroup().position,
         XMessagePopupText.getGroup().getGroup().position
      )
   );
   %x = getWord(%pos, 0);
   %y = getWord(%pos, 1) + 36;
   // ENG_Type.resize(%x, %y, getWord(ENG_Type.extent, 0), getWord(ENG_Type.extent, 1));
}

function EnterNameCreateProfileGui::hide(%this)
{
   XMessagePopupDlg.hide();
   EnterNameGui.add(ENG_Type);
   activateKeyboard();
}

function EnterNameCreateProfileGui::apply(%this)
{
   $Player::Name = %this.gamertag;
   $pref::Player::UsingCustomName = true;
   $pref::Player::Name = $Player::Name;

   %recoverycode = garbledeguck(ENG_TypeRecov.getText());

	if (%this.mode $= "CREATE")
	{
		if (isObject(CreateAccount))
			CreateAccount.delete();
		new HTTPObject(CreateAccount);
		CreateAccount.post($Online::PlatformLink, "/api/account/AccountCreation.php", "", "requestedname=" @ $Player::Name @ "&recoverycode=" @ %recoverycode);
	}
	else if (%this.mode $= "LOGIN")
	{
		if (isObject(RecoverAccount))
			RecoverAccount.delete();
		new HTTPObject(RecoverAccount);
		RecoverAccount.post($Online::PlatformLink, "/api/account/RecoverLogInAccount.php", "", "username=" @ $Player::Name @ "&recoverycode=" @ %recoverycode);
	}

   Canvas.popDialog(%this);
}

function EnterNameCreateProfileGui::cancel(%this)
{
	Canvas.popDialog(%this);
	MyProfileGui.offlineaccprotocol();
}

function ENG_Type::type(%this)
{
   EnterNameCreateProfileGui.gamertag = %this.getText();  
}

function ENG_Type::send(%this)
{
   EnterNameCreateProfileGui.apply();
}

function ENG_TypeRecov::type(%this)
{
   // Nothing
}